{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "tomsun-line": ["../../src/index.ts"],
      "tomsun-line/adapters/Vue": ["../../src/adapters/Vue/index.ts"],
      "tomsun-line/adapters/React": ["../../src/adapters/React/index.ts"]
    }
  },
  "include": ["src"]
}
